{
  "manifest_version": 3,
  "name": "Claude Context Tracker",
  "version": "1.2.0",
  "description": "Real-time context window, usage limits and credit tracker for Claude Chat",
  "permissions": ["webRequest", "storage", "alarms"],
  "host_permissions": ["https://claude.ai/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://claude.ai/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
