{
  "manifest_version": 3,
  "name": "Claude Context Tracker",
  "version": "1.0.0",
  "description": "Real-time context window usage tracker for Claude Chat",
  "content_scripts": [
    {
      "matches": ["https://claude.ai/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
